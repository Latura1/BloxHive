<UserControl x:Class="BloxHive.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:BloxHive.ViewModels"
             d:DataContext="{d:DesignInstance vm:DashboardViewModel}"
             mc:Ignorable="d">
    <ScrollViewer Padding="40" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0 0 0 32">
                <Border Width="48" Height="48" CornerRadius="14" Background="{DynamicResource BrushAccent}" VerticalAlignment="Center">
                    <TextBlock Text="&#xE7C1;" FontFamily="Segoe MDL2 Assets" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="16 0 0 0">
                    <TextBlock Text="{Binding Loc.Dashboard}" FontSize="22" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="{Binding Loc.DashboardDescription}" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Margin="0 4 0 0" />
                </StackPanel>
            </StackPanel>

            <Border Style="{StaticResource Card}" Margin="0 0 0 16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding StatusText}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center" />
                        </StackPanel>

                        <Border Background="{DynamicResource BrushSurfaceDarkTertiary}" CornerRadius="10" Padding="14" Margin="0 14 0 0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE774;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="#22C55E" VerticalAlignment="Center" Margin="0 0 8 0" />
                                    <TextBlock Text="Cloudflare Tunnel" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0 8 0 0">
                                    <TextBlock Text="{Binding TunnelUrl}" FontSize="14" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                                    <Button Command="{Binding CopyLinkCommand}" Width="30" Height="30" Padding="0" Margin="8 0 0 0"
                                            Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}"
                                            BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Button>
                                </StackPanel>
                                <TextBlock Text="{Binding Loc.DashboardTunnelDescription}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" Margin="0 6 0 0" />
                            </StackPanel>
                        </Border>

                        <StackPanel Visibility="{Binding ShowNetworkDetails, Converter={StaticResource BoolToVisibility}}" Margin="0 10 0 0">
                            <Border Background="{DynamicResource BrushSurfaceDarkTertiary}" CornerRadius="10" Padding="14">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0 0 0 6">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center" Margin="0 0 8 0" />
                                        <TextBlock Text="{Binding Loc.DashboardLocalNetwork}" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding NetworkUrl}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" Margin="0 0 0 4" />
                                    <TextBlock Text="{Binding LocalUrl}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" />
                                    <TextBlock Text="{Binding Loc.DashboardUrlHint}" FontSize="10" Foreground="{DynamicResource BrushTextMuted}" Margin="0 8 0 0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Top" Orientation="Horizontal">
                        <Button Command="{Binding StartCommand}" IsEnabled="{Binding CanStart}" Margin="0 0 8 0"
                                Height="36" Padding="16 0" Background="{DynamicResource BrushAccent}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                FontSize="13" FontWeight="SemiBold">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="border" Property="Opacity" Value="0.4" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0 0 6 0" />
                                <TextBlock Text="{Binding Loc.DashboardStart}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource DangerButton}" Command="{Binding StopCommand}" IsEnabled="{Binding CanStop}"
                                Height="36">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE71A;" FontFamily="Segoe MDL2 Assets" FontSize="13" VerticalAlignment="Center" Margin="0 0 6 0" />
                                <TextBlock Text="{Binding Loc.DashboardStop}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Background="#20EF4444" CornerRadius="12" Padding="16" Margin="0 0 0 16" Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="{DynamicResource BrushDanger}" TextWrapping="Wrap" />
            </Border>

            <Border Style="{StaticResource Card}" Margin="0 0 0 16">
                <StackPanel>
                    <TextBlock Text="{Binding Loc.DashboardPort}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="{Binding Loc.DashboardPortDescription}" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Margin="0 4 0 20" />

                    <Border Background="{DynamicResource BrushSurfaceDarkTertiary}" CornerRadius="12" Padding="20">
                        <StackPanel>
                            <Grid Visibility="{Binding CanEditPort, Converter={StaticResource BoolToVisibility}}" Margin="0 0 0 16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Port" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding Port, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="16 0 8 0"
                                         Style="{StaticResource SettingsInput}" Height="36" />
                                <Button Grid.Column="2" Style="{StaticResource DangerButton}" Command="{Binding ResetPortCommand}"
                                        Content="{Binding Loc.DashboardReset}" />
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding Loc.DashboardPassword}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center" />
                                <TextBox Grid.Column="1" Text="{Binding PasswordInput, UpdateSourceTrigger=PropertyChanged}" Width="180" HorizontalAlignment="Left" Margin="16 0 8 0"
                                         Style="{StaticResource SettingsInput}" Height="36" />
                                <Button Grid.Column="2" Command="{Binding SetPasswordCommand}" Margin="0 0 6 0"
                                        Height="36" Padding="16 0" Background="{DynamicResource BrushAccent}" Foreground="White" BorderThickness="0" Cursor="Hand"
                                        FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                                        Content="{Binding Loc.DashboardSetPassword}">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}" Cursor="Hand">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Grid.Column="3" Style="{StaticResource DangerButton}" Command="{Binding ResetPasswordCommand}"
                                        Content="{Binding Loc.DashboardReset}" Margin="0 0 0 0" />
                            </Grid>
                        </StackPanel>
                    </Border>
                    <TextBlock Text="{Binding PasswordStatusText}" FontSize="12" Foreground="{DynamicResource BrushAccent}" Margin="0 10 0 0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="{Binding Loc.DashboardQR}" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="{Binding Loc.DashboardQRDescription}" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" Margin="0 4 0 20" />

                    <Border Background="{DynamicResource BrushSurfaceDarkTertiary}" CornerRadius="16" Padding="24" HorizontalAlignment="Center">
                        <Border CornerRadius="12" Background="{DynamicResource BrushSurfaceDark}" Padding="12">
                            <Image Source="{Binding QrCodeImage}" Width="180" Height="180" />
                        </Border>
                    </Border>

                    <Border Background="{DynamicResource BrushSurfaceDarkTertiary}" CornerRadius="10" Padding="14" HorizontalAlignment="Center" Margin="0 16 0 0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding TunnelUrl}" FontSize="14" Foreground="{DynamicResource BrushTextPrimary}" FontWeight="SemiBold" VerticalAlignment="Center" TextWrapping="Wrap" />
                            <Button Command="{Binding CopyLinkCommand}" Width="30" Height="30" Padding="0" Margin="8 0 0 0"
                                    Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}"
                                    BorderThickness="0" Cursor="Hand" VerticalAlignment="Center">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Button>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding NetworkUrl}" FontSize="11" Foreground="{DynamicResource BrushAccent}" HorizontalAlignment="Center" Margin="0 6 0 0"
                               Visibility="{Binding ShowNetworkDetails, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock Text="{Binding Loc.DashboardTunnelDescription}" FontSize="11" Foreground="{DynamicResource BrushTextMuted}" HorizontalAlignment="Center" Margin="0 4 0 0" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
