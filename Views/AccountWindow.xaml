<Window x:Class="BloxHive.Views.AccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="BloxHive - Account" Width="1200" Height="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">
        <Border CornerRadius="12" Background="{DynamicResource BrushSurfaceDark}" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource BrushSurfaceDarkSecondary}" CornerRadius="12 12 0 0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16 0 0 0" VerticalAlignment="Center">
                    <Border Width="20" Height="20" CornerRadius="6" Background="{DynamicResource BrushAccent}">
                        <TextBlock Text="B" FontSize="11" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock x:Name="TitleText" Text="BloxHive - Account" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center" Margin="10 0 0 0" />
                </StackPanel>

                <Button Grid.Column="2" Width="46" Height="28" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" Cursor="Hand" Click="ReloadClick" Margin="0 0 4 0">
                    <TextBlock Text="&#xE72D;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" />
                </Button>

                <Button Grid.Column="3" Height="28" Padding="12 0" Background="{DynamicResource BrushSurfaceDarkTertiary}" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" Cursor="Hand" Click="ClearCacheClick" Margin="0 0 4 0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Cache leeren" FontSize="12" VerticalAlignment="Center" />
                    </StackPanel>
                </Button>

                <Button Grid.Column="4" Width="46" Height="28" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" Cursor="Hand" Click="CloseClick">
                    <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                </Button>
                    </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0">
                <wv2:WebView2 x:Name="AccountWebView" />
            </Grid>
        </Grid>
    </Border>
</Window>
