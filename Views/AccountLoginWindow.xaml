<Window x:Class="BloxHive.Views.AccountLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="{Binding Loc.AccountLoginTitle}" Width="800" Height="700"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Border CornerRadius="12" Background="{DynamicResource BrushSurfaceDark}" BorderThickness="1" BorderBrush="{DynamicResource BrushBorder}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44" />
                <RowDefinition Height="*" />
                <RowDefinition Height="52" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource BrushSurfaceDarkSecondary}" CornerRadius="12 12 0 0" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{DynamicResource BrushAccent}" VerticalAlignment="Center" Margin="16 0 0 0" />
                    <TextBlock Grid.Column="0" Text="{Binding Loc.AccountLoginTitle}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource BrushTextPrimary}" VerticalAlignment="Center" Margin="38 0 0 0" />
                    <Button Grid.Column="2" Width="36" Height="28" Background="Transparent" Foreground="{DynamicResource BrushTextSecondary}" BorderThickness="0" Cursor="Hand" Click="CloseClick" Margin="0 0 8 0">
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10" />
                    </Button>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0">
                <wv2:WebView2 x:Name="LoginWebView" />
                <Border x:Name="LoadingOverlay" Background="#CC000000" Visibility="Visible">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock x:Name="StatusText" Text="{Binding Loc.AccountLoginLoading}" FontSize="15" Foreground="{DynamicResource BrushTextPrimary}" HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{DynamicResource BrushSurfaceDarkSecondary}" CornerRadius="0 0 12 12" Padding="12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="InfoText" Grid.Column="0" Text="{Binding Loc.AccountLoginInfo}" FontSize="12" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" Margin="8 0 0 0" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="CancelButton" Content="{Binding Loc.Cancel}" Height="34" Padding="16 0" Background="{DynamicResource BrushSurfaceDarkTertiary}" Foreground="{DynamicResource BrushTextPrimary}" BorderThickness="0" Cursor="Hand" Click="CloseClick">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="DoneButton" Content="{Binding Loc.Done}" Height="34" Padding="16 0" Background="{DynamicResource BrushAccent}" Foreground="White" BorderThickness="0" Cursor="Hand" Click="DoneClick" Margin="8 0 0 0" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}" Height="{TemplateBinding Height}" Cursor="Hand">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Opacity" Value="0.85" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
