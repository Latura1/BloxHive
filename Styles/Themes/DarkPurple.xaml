<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Color x:Key="SurfaceDark">#0D0A14</Color>
    <Color x:Key="SurfaceDarkSecondary">#1A1228</Color>
    <Color x:Key="SurfaceDarkTertiary">#2D1F3F</Color>
    <Color x:Key="Accent">#8B5CF6</Color>
    <Color x:Key="AccentLight">#A78BFA</Color>
    <Color x:Key="AccentDark">#7C3AED</Color>
    <Color x:Key="SurfaceLight">#1E1E1E</Color>
    <Color x:Key="Background">#0F0A1A</Color>
    <Color x:Key="CardBackground">#1A1228</Color>
    <Color x:Key="TextPrimary">#F5F3FF</Color>
    <Color x:Key="TextSecondary">#C4B5E3</Color>
    <Color x:Key="TextMuted">#8B7FAD</Color>
    <Color x:Key="Border">#2D1F3F</Color>
    <Color x:Key="Hover">#2D1F3F</Color>
    <Color x:Key="Success">#10B981</Color>
    <Color x:Key="Warning">#F59E0B</Color>
    <Color x:Key="Error">#EF4444</Color>

    <SolidColorBrush x:Key="BrushSurfaceDark" Color="{StaticResource SurfaceDark}" />
    <SolidColorBrush x:Key="BrushSurfaceDarkSecondary" Color="{StaticResource SurfaceDarkSecondary}" />
    <SolidColorBrush x:Key="BrushSurfaceDarkTertiary" Color="{StaticResource SurfaceDarkTertiary}" />
    <SolidColorBrush x:Key="BrushAccent" Color="{StaticResource Accent}" />
    <SolidColorBrush x:Key="BrushAccentLight" Color="{StaticResource AccentLight}" />
    <SolidColorBrush x:Key="BrushAccentDark" Color="{StaticResource AccentDark}" />
    <SolidColorBrush x:Key="BrushSurfaceLight" Color="{StaticResource SurfaceLight}" />
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource Background}" />
    <SolidColorBrush x:Key="BrushCardBackground" Color="{StaticResource CardBackground}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource TextMuted}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="BrushHover" Color="{StaticResource Hover}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource Success}" />
    <SolidColorBrush x:Key="BrushWarning" Color="{StaticResource Warning}" />
    <SolidColorBrush x:Key="BrushError" Color="{StaticResource Error}" />

</ResourceDictionary>
